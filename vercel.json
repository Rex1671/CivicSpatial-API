{
  "functions": {
    "api/representatives.js": {
      "memory": 1024,
      "maxDuration": 45,
      "includeFiles": "vercel_data/constituencies/**/*.geojson"
    },
    "api/wards.js": {
      "memory": 1024,
      "maxDuration": 45,
      "includeFiles": "vercel_data/wards/**/*.geojson"
    },
    "api/infrastructure.js": {
      "memory": 1024,
      "maxDuration": 45,
      "includeFiles": "vercel_data/infra/**/*.geojson"
    },
    "api/jurisdiction.js": {
      "memory": 1024,
      "maxDuration": 45
    },
    "api/electoral.js": {
      "memory": 1024,
      "maxDuration": 45,
      "includeFiles": "vercel_data/constituencies/**/*.geojson"
    },
    "api/health.js": {
      "memory": 128,
      "maxDuration": 5
    }
  },
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api/$1" },
    { "source": "/(.*)", "destination": "/public/$1" }
  ],
  "cleanUrls": true
}
